# Brainboard export
tf-import/
brainboard-export/

# Terraform Files
# Local .terraform directories
.terraform/
**/.terraform/

# .tfstate files
*.tfstate
*.tfstate.*
terraform.tfstate.d/
**/terraform.tfstate.d/

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars
*.tfvars.json
*.auto.tfvars
*.auto.tfvars.json
# Allow committed environment variable files (non-sensitive values only)
!platform/terraform/env/*.tfvars

# Ignore backend configuration files (may contain sensitive S3/DynamoDB info)
backend.hcl
*.tfbackend

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files created by terraform apply
.terraform.tfstate.lock.info

# Include override files you do wish to add to version control using negated pattern
# !example_override.tf

# Include tfplan files to ignore the plan output of command: terraform plan -out=tfplan
# example: *tfplan*

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Terraform / Inframap generated outputs (can expose infra topology and metadata)
*.tfplan
*tfplan*
planout
*.plan
*.dot
*.gv
*.graphml
inframap.json
inframap.dot
platform/terraform/plan.txt
platform/terraform/plan.out
platform/terraform/plan.json
platform/terraform/lab-outputs.json
tf-import/*

# Generated infrastructure diagrams
docs/infrastructure/generated/*

# Gradle
.gradle/
.gradle-home/
.gradle-local/
.gradle-user-home/
**/.gradle/
**/.gradle-local/
**/.gradle-user-home/
**/.gradle-test-home/
.gradle-user-home-backend-pipeline/

# Python / pytest cache
.venv/
**/.venv/
venv/
**/venv/
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*$py.class
.coverage
.coverage.*
.pytest_cache/
**/.pytest_cache/
pytest-cache-files-*/
**/pytest-cache-files-*/
**/.hypothesis/
**/build/reports/tests/
**/build/reports/coverage/
**/.cache/black/
**/.ruff_cache/
**/.mypy_cache/

# Private Keys - do not commit any secrets
*.pem
*.key
id_rsa
*.ppk

# Others
.DS_Store
.env
.env.local

# Developer Setup - Portable Tools
.devtools/

# Ignore IDE Configs
.vscode/*
.VSCodeCounter/

# Ignore Local Dev Files / Notes
TODO.md
CHANGELOG.md
NOTES.md
temp/*
fail-logs/*
docs/diff/

# Debug Screenshots
services/frontend/crm-ui/debug-*.png

# Pipeline & Build-Logs 
scripts/legacy/**/build-logs/
build-logs/migration-validation/
**/new-*.log
**/old-*.log
/build-logs/
test-results/

# Local CI-generated Terraform artifact zips
.ci-artifacts/
*.zip

# Brainboard import generated artifacts and local state/secrets
brainboard-import/.generated-lambda-artifacts/

# Keep core Brainboard Terraform files tracked for import/visualization
!brainboard-import/*.tf
!brainboard-import/*.tf.json
!brainboard-import/.terraform.lock.hcl
brainboard-export/

# Ignore Test Directories
node_modules/

# Hypothesis (property-based testing) local cache
.hypothesis/

# Java build outputs (Gradle/Maven)
*.class
**/target/
**/build/
